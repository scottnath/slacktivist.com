---
import { readFileSync, existsSync } from 'node:fs';
import { dirname, join } from 'node:path';
import { fileURLToPath } from 'node:url';
import type { CollectionEntry } from 'astro:content';
import { generateDocumentLinkTag } from '@scottnath/devx/atproto';
import BlogComments from '../components/BlogComments.astro';
import Layout from './Layout.astro';

interface Props {
  entry: CollectionEntry<'blog'>;
}

const { entry } = Astro.props;
const { title, description, date, atprotoRkey, bskyPostUri } = entry.data;

const canonicalUrl = Astro.site
  ? new URL(`${import.meta.env.BASE_URL}blog/${entry.id}/`, Astro.site).href
  : undefined;

const root = join(dirname(fileURLToPath(import.meta.url)), '../..');
const didPath = join(root, 'public/.well-known/atproto-did');
const did = existsSync(didPath) ? readFileSync(didPath, 'utf8').trim() : undefined;

const documentLinkTag =
  atprotoRkey && did ? generateDocumentLinkTag(did, atprotoRkey) : null;
---

<Layout title={title}>
  <Fragment slot="head">
    {documentLinkTag && <Fragment set:html={documentLinkTag} />}
  </Fragment>

  <article>
    <header>
      <h1>{title}</h1>
      {description && <p class="blog-description">{description}</p>}
      <time datetime={date.toISOString()}>{date.toLocaleDateString('en-US', { dateStyle: 'long' })}</time>
    </header>
    <div class="blog-body">
      <slot />
    </div>
  </article>

  <BlogComments bskyPostUri={bskyPostUri} canonicalUrl={canonicalUrl} />
</Layout>

<style>
  .blog-description {
    font-size: 1.125rem;
    opacity: 0.85;
  }

  time {
    display: block;
    margin-top: 0.5rem;
    font-size: 0.875rem;
    opacity: 0.7;
  }

  .blog-body :global(h2) {
    margin-top: 2rem;
  }
</style>
