---
import { readFileSync, existsSync } from 'node:fs';
import { dirname, join } from 'node:path';
import { fileURLToPath } from 'node:url';
import type { CollectionEntry } from 'astro:content';
import DevxBlogPost from '@scottnath/devx/atproto/components/BlogPost.astro';
import { generateDocumentLinkTag } from '@scottnath/devx/atproto';
import Layout from './Layout.astro';

interface Props {
  entry: CollectionEntry<'blog'>;
}

const { entry } = Astro.props;
const { title, description, date, atprotoRkey, bskyPostUri, ogImage } = entry.data;

const canonicalUrl = Astro.site
  ? new URL(`${import.meta.env.BASE_URL}blog/${entry.id}/`, Astro.site).href
  : undefined;

const root = join(dirname(fileURLToPath(import.meta.url)), '../..');
const didPath = join(root, 'public/.well-known/atproto-did');
const did = existsSync(didPath) ? readFileSync(didPath, 'utf8').trim() : undefined;

const documentLinkTag =
  atprotoRkey && did ? generateDocumentLinkTag(did, atprotoRkey) : null;
---

<Layout title={title} description={description} ogImagePath={ogImage}>
  <Fragment slot="head">
    {documentLinkTag && <Fragment set:html={documentLinkTag} />}
  </Fragment>

  <DevxBlogPost
    title={title}
    description={description}
    date={date}
    bskyPostUri={bskyPostUri}
    canonicalUrl={canonicalUrl}
    ogImage={ogImage}
  >
    <slot />
  </DevxBlogPost>
</Layout>
