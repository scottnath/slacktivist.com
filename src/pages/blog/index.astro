---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
---

<Layout title="Blog">
  <h1>Blog</h1>
  {
    posts.length === 0 ? (
      <p>No posts yet.</p>
    ) : (
      <ul class="blog-index">
        {posts.map((post) => (
          <li>
            <a href={`${import.meta.env.BASE_URL}blog/${post.id}/`}>{post.data.title}</a>
            <time datetime={post.data.date.toISOString()}>
              {post.data.date.toLocaleDateString('en-US', { dateStyle: 'medium' })}
            </time>
          </li>
        ))}
      </ul>
    )
  }
</Layout>

<style>
  .blog-index {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .blog-index li {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .blog-index time {
    font-size: 0.875rem;
    opacity: 0.7;
  }
</style>
